# Training artifacts — large + reproducible. Keep local.
# (Use `dir/*` rather than `dir/` so the .gitkeep placeholder still tracks.)
inputs/*
outputs/*
**/log/
**/logs/
**/runs/
**/hf_cache/
final_model/
checkpoint-*/

# Python caches / build
**/__pycache__/
**/*.py[cod]
**/.pytest_cache/
**/.ipynb_checkpoints/
*.egg-info/
build/
dist/

# Editor / OS
.vscode/
.idea/
.DS_Store

# Backups + scratch
*.bak
*.tmp
*.swp
*~
_backup_*/
Untitled-*.ipynb

# Secrets
.env
.env.*
!.env.example

# SLURM cluster outputs
*.log
*.err
slurm-*.out

# Local venv
.venv/
venv/

# Allow placeholders so the empty inputs/outputs trees survive a clone
!inputs/.gitkeep
!outputs/.gitkeep
